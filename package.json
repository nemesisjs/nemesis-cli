{
  "name": "@nemesis-js/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "NemesisJS CLI - scaffolding and code generation",
  "author": "NemesisJS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nemesisjs/cli.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "nemesis": "./bin/nemesis.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@nemesis-js/schematics": "^0.1.1",
    "chalk": "^5.3.0",
    "figlet": "^1.11.0",
    "gradient-string": "^2.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "typescript": "^5.7.0"
  }
}
