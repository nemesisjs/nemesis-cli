{
  "name": "@nemesisjs/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "NemesisJS CLI - scaffolding and code generation",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "nemesis": "./bin/nemesis.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test"
  },
  "dependencies": {
    "@nemesisjs/common": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
